{
  "font": {
    "size": {
      "$type": "fontSize",
      "xs": { "$value": "0.75rem", "$description": "12px，标签、徽章" },
      "sm": { "$value": "0.875rem", "$description": "14px，辅助文字" },
      "base": { "$value": "1rem", "$description": "16px，正文基准" },
      "lg": { "$value": "1.125rem", "$description": "18px，大号正文" },
      "xl": { "$value": "1.25rem", "$description": "20px，小标题" },
      "2xl": { "$value": "1.5rem", "$description": "24px，中标题" },
      "3xl": { "$value": "1.875rem", "$description": "30px，大标题" },
      "4xl": { "$value": "2.25rem", "$description": "36px，超大标题" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400, "$description": "常规字重" },
      "medium": { "$value": 500, "$description": "中等字重，强调正文" },
      "semibold": { "$value": 600, "$description": "半粗字重，小标题、按钮" },
      "bold": { "$value": 700, "$description": "粗体，大标题、强强调" }
    },
    "line-height": {
      "$type": "lineHeight",
      "tight": { "$value": 1.1, "$description": "紧凑行高，用于大标题" },
      "snug": { "$value": 1.25, "$description": " snug 行高，用于小标题" },
      "base": { "$value": 1.5, "$description": "标准行高，正文阅读" },
      "relaxed": { "$value": 1.75, "$description": "宽松行高，长文阅读" }
    },
    "letter-spacing": {
      "$type": "letterSpacing",
      "tight": { "$value": "-0.02em", "$description": "紧凑字距，大标题更凝聚" },
      "normal": { "$value": "0em", "$description": "标准字距" },
      "wide": { "$value": "0.05em", "$description": "宽字距，用于大写标签" }
    }
  }
}
