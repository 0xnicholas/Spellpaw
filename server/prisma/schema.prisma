generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./spellpaw.db"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Capability-grouped model configs. JSON: { text: ModelConfig, image: ModelConfig, video: ModelConfig }
  // Sole LLM config surface. Drama canvas toolkit reads via
  // capabilityConfig.ts. Drama no longer maintains per-provider
  // spellpaw_settings.{openai,doubao,minimax}ApiKey fields.
  llmConfigs    String?

  projects  Project[]
  tasks     Task[]
  chats     Chat[]
}

model Task {
  id        String   @id @default(uuid())
  userId    String
  projectId String?
  title     String
  status    String
  messages  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model Chat {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  messages  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String   @default("")
  coverColor  String   @default("#6366f1")
  data        String   // JSON: { cards: CanvasNode[], edges: CanvasEdge[] }
  version     Int      @default(1)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id])
}
